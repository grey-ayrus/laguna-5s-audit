# =============================================================================
# Local development
# =============================================================================
PORT=5000
MONGODB_URI=mongodb://localhost:27017/laguna-5s-audit
ENGINE_URL=http://localhost:5001
NODE_ENV=development

# =============================================================================
# Online vision providers (optional)
# =============================================================================
# Individual users can paste their own key into the in-app Settings page —
# those keys stay in their browser's localStorage and are sent straight to
# the provider, never persisted server-side.
# Set either of these in .env if you want a shared server-side fallback key.
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...

# =============================================================================
# Vercel deployment (set these in the Vercel project -> Settings -> Environment
# Variables; do NOT commit them here)
# =============================================================================
# MONGODB_URI            Mongo Atlas connection string (required for persistence)
# GROQ_API_KEY           fallback key if the browser doesn't send one
# OPENAI_API_KEY         fallback key if the browser doesn't send one
# BLOB_READ_WRITE_TOKEN  automatic when you enable Vercel Blob in the project
# ENGINE_URL             optional: URL of an external Python engine, leave
#                        unset and the deployed app will rely on Groq/OpenAI
